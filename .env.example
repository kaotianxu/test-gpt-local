# Required: Runtime API key for tunnel-client to access the OpenAI Tunnel control plane.
# Generate this from OpenAI Platform → Tunnel Settings.
CONTROL_PLANE_API_KEY=

# Proxy configuration for tunnel-client control plane traffic.
# The MCP server's localhost traffic bypasses this proxy.
CONTROL_PLANE_HTTP_PROXY=http://127.0.0.1:7897
HTTP_PROXY=http://127.0.0.1:7897
HTTPS_PROXY=http://127.0.0.1:7897
ALL_PROXY=http://127.0.0.1:7897
NO_PROXY=127.0.0.1,localhost,::1